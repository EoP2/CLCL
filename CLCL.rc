IDR_MENU_POPUP MENU
BEGIN
    POPUP "Clipboard"
    BEGIN
        MENUITEM "&Add to Template...\tCtrl+R", ID_MENUITEM_REGIST_ADD
        MENUITEM "&Save As...\tCtrl+S",         ID_MENUITEM_DATA_SAVE
        MENUITEM SEPARATOR
        POPUP "&Options"
        BEGIN
            MENUITEM "&Format...",                  ID_MENUITEM_SET_FORMAT
            MENUITEM "Fi&lter...",                  ID_MENUITEM_SET_FILTER
        END
    END
    POPUP "History(TV)"
    BEGIN
        MENUITEM "Send to &Clipboard\tCtrl+C",  ID_MENUITEM_CLIPBOARD
        MENUITEM "&Paste from Clipboard\tCtrl+V", ID_MENUITEM_PASTE
        MENUITEM "&Add to Template...\tCtrl+R", ID_MENUITEM_REGIST_ADD
        MENUITEM "&Tools",                      ID_MENUITEM_TOOL_MENU
        MENUITEM SEPARATOR
        MENUITEM "Move &Up\tAlt+Up",            ID_MENUITEM_UP
        MENUITEM "Move Do&wn\tAlt+Down",        ID_MENUITEM_DOWN
        MENUITEM SEPARATOR
        MENUITEM "&New Item...\tCtrl+N",        ID_MENUITEM_NEW_ITEM
        MENUITEM "&Save As...\tCtrl+S",         ID_MENUITEM_DATA_SAVE
        POPUP "&Options"
        BEGIN
            MENUITEM "&Format...",                  ID_MENUITEM_SET_FORMAT
            MENUITEM "Fi&lter...",                  ID_MENUITEM_SET_FILTER
        END
        MENUITEM SEPARATOR
        MENUITEM "&Delete",                     ID_MENUITEM_DELETE
    END
    POPUP "History(LV)"
    BEGIN
        MENUITEM "&Open",                       ID_MENUITEM_OPEN
        MENUITEM SEPARATOR
        MENUITEM "Send to &Clipboard\tCtrl+C",  ID_MENUITEM_CLIPBOARD
        MENUITEM "&Paste from Clipboard\tCtrl+V", ID_MENUITEM_PASTE
        MENUITEM "&Add to Template...\tCtrl+R", ID_MENUITEM_REGIST_ADD
        MENUITEM "&Tools",                      ID_MENUITEM_TOOL_MENU
        MENUITEM SEPARATOR
        MENUITEM "Move &Up\tAlt+Up",            ID_MENUITEM_UP
