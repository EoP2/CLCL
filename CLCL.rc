IDR_MENU_VIEWER MENU
BEGIN
    POPUP "文件(&F)"
    BEGIN
        MENUITEM "新建(&N)...\tCtrl+N",         ID_MENUITEM_NEW_ITEM
        MENUITEM "另存为(&S)...\tCtrl+S",     ID_MENUITEM_DATA_SAVE
        MENUITEM SEPARATOR
        MENUITEM "保存当前状态(&T)\tSCtrl+S",       ID_MENUITEM_SAVE
        MENUITEM SEPARATOR
        MENUITEM "导入(&I)...",                ID_MENUITEM_IMPORT
        MENUITEM "导出(&E)...",               ID_MENUITEM_EXPORT
        MENUITEM SEPARATOR
        MENUITEM "监视剪贴板(&W)",              ID_MENUITEM_WATCH
        MENUITEM SEPARATOR
        MENUITEM "关闭此窗口(&C)",             ID_MENUITEM_CLOSE
        MENUITEM "退出(&X)",                      ID_MENUITEM_EXIT
    END
    POPUP "编辑(&E)"
    BEGIN
        MENUITEM "复制到剪贴板(&C)\tCtrl+C",      ID_MENUITEM_CLIPBOARD
        MENUITEM "从剪贴板粘贴(&P)\tCtrl+V",   ID_MENUITEM_PASTE
        MENUITEM "添加到收藏(&R)...\tCtrl+R",    ID_MENUITEM_REGIST_ADD
        MENUITEM SEPARATOR
        MENUITEM "上移(&U)\tAlt+↑",               ID_MENUITEM_UP
        MENUITEM "下移(&W)\tAlt+↓",               ID_MENUITEM_DOWN
        MENUITEM SEPARATOR
        MENUITEM "删除(&D)",                      ID_MENUITEM_DELETE
        MENUITEM SEPARATOR
        MENUITEM "全选(&A)\tCtrl+A",           ID_MENUITEM_SELECT_ALL
    END
    POPUP "显示(&V)"
    BEGIN
        MENUITEM "工具栏(&T)",                  ID_MENUITEM_SHOW_TOOLBAR
        MENUITEM "状态栏(&S)",                ID_MENUITEM_SHOW_STATUSBAR
        MENUITEM SEPARATOR
        MENUITEM "在树形列表中显示格式(&F)",               ID_MENUITEM_SHOW_FORMAT
        MENUITEM "二进制显示(&B)",                  ID_MENUITEM_SHOW_BIN
        MENUITEM SEPARATOR
        MENUITEM "选项(&O)...",                ID_MENUITEM_OPTION
    END
    POPUP "插件(&T)"
    BEGIN
        MENUITEM "插件设置(&O)...",                ID_MENUITEM_TOOL_SET
        MENUITEM SEPARATOR
    END
    POPUP "帮助(&H)"
    BEGIN
        MENUITEM "关于(&A)...",              ID_MENUITEM_ABOUT
    END
END

